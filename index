<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Social Media für Handwerker — Wissensbaustein für Handwerksbetriebe</title>
<meta name="description" content="Der ehrliche Grund, warum Du nicht postest, hat nichts mit Können zu tun. Heute Abend mit Handy in 7 Minuten lösen.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0e0d0b;
    --bg-card: #18171a;
    --bg-card-soft: #1f1d20;
    --yellow: #f5c518;
    --yellow-soft: #ffd84a;
    --ink-on-yellow: #0e0d0b;
    --ink: #f5f1e8;
    --ink-soft: #b5ad9e;
    --ink-muted: #7a7269;
    --line: #2a2825;
    --done: #6ec472;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 32px; }
  .wrap-narrow { max-width: 820px; margin: 0 auto; padding: 0 32px; }
  h1, h2, h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  h1 { font-size: clamp(1.5rem, 3vw, 2.4rem); font-weight: 800; }
  h2 { font-size: clamp(1.9rem, 4.2vw, 3rem); margin-bottom: 1rem; line-height: 1.08; }
  h3 { font-size: clamp(1.2rem, 2.4vw, 1.5rem); margin-bottom: 0.5rem; line-height: 1.2; }
  p { margin-bottom: 1rem; color: var(--ink-soft); font-size: 1.04rem; }
  strong { color: var(--ink); font-weight: 600; }
  em { font-style: italic; }
  .yellow { color: var(--yellow); }

  header { padding: 22px 0; }
  .header-inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; }
  .logo { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 900; font-size: 1.05rem; color: var(--ink); display: flex; align-items: center; gap: 10px; }
  .logo .yellow-dot { color: var(--yellow); }
  .logo-meta { font-size: 0.74rem; color: var(--ink-muted); font-family: 'JetBrains Mono', monospace; text-transform: uppercase; letter-spacing: 0.1em; }
  .header-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: var(--yellow);
    border: 1.5px solid var(--yellow);
    padding: 10px 18px;
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.18s ease;
    white-space: nowrap;
  }
  .header-btn:hover { background: var(--yellow); color: var(--ink-on-yellow); transform: translateY(-1px); }
  .header-btn-arrow { font-size: 1rem; transition: transform 0.2s ease; }
  .header-btn:hover .header-btn-arrow { transform: translateX(3px); }
  @media (max-width: 600px) {
    .header-btn { font-size: 0.7rem; padding: 8px 14px; }
    .header-btn-text-long { display: none; }
  }

  /* HERO */
  .hero { padding: 60px 0 70px; position: relative; overflow: hidden; }
  .hero::before {
    content: ""; position: absolute; top: 30px; left: 30px; width: 120px; height: 120px;
    background-image: radial-gradient(circle, rgba(245,197,24,0.18) 1.5px, transparent 1.5px);
    background-size: 14px 14px; pointer-events: none; opacity: 0.7;
  }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: center; position: relative; z-index: 2; }
  @media (max-width: 900px) { .hero-grid { grid-template-columns: 1fr; gap: 40px; } }
  .pill {
    display: inline-block; border: 1.5px solid var(--yellow); color: var(--yellow);
    padding: 9px 18px; border-radius: 100px; font-weight: 700; font-size: 0.72rem;
    letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 32px;
  }
  .hero h1 { color: var(--ink); margin-bottom: 28px; }
  .hero h1 .strike-out {
    text-decoration: line-through; text-decoration-thickness: 5px;
    text-decoration-color: var(--yellow); color: var(--ink-muted);
  }
  .hero-lead { font-size: 1.08rem; color: var(--ink-soft); margin-bottom: 12px; max-width: 580px; }
  .hero-emph { color: var(--yellow); font-weight: 600; margin-bottom: 38px; font-size: 1.08rem; }
  .hero-cta {
    display: inline-block; background: var(--yellow); color: var(--ink-on-yellow);
    padding: 18px 36px; border-radius: 4px; font-weight: 700; font-size: 0.86rem;
    letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
    border: none; cursor: pointer; transition: all 0.15s ease;
  }
  .hero-cta:hover { background: var(--yellow-soft); transform: translateY(-2px); }
  .hero-meta { margin-top: 60px; padding-top: 28px; border-top: 1px solid var(--line); display: flex; gap: 60px; flex-wrap: wrap; }
  .hero-meta-num { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.7rem; font-weight: 800; color: var(--yellow); display: block; margin-bottom: 4px; }
  .hero-meta-label { font-size: 0.7rem; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.12em; font-family: 'JetBrains Mono', monospace; }

  /* STATEMENT SECTION (zwischen Hero und Credibility) */
  .statement {
    background: var(--bg);
    padding: 80px 0;
    text-align: center;
    border-top: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .statement::before {
    content: "";
    position: absolute;
    top: 30px;
    right: 30px;
    width: 120px;
    height: 120px;
    background-image: radial-gradient(circle, rgba(245,197,24,0.18) 1.5px, transparent 1.5px);
    background-size: 14px 14px;
    pointer-events: none;
    opacity: 0.7;
  }
  .statement-h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.7rem, 4.4vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--ink);
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .statement-h2 .strike-out {
    text-decoration: line-through;
    text-decoration-thickness: 5px;
    text-decoration-color: var(--yellow);
    color: var(--ink-muted);
  }
  .statement-h2 .yellow { color: var(--yellow); }

  /* DREI WEGE */
  .wege-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 50px;
  }
  @media (max-width: 900px) { .wege-grid { grid-template-columns: 1fr; } }
  .weg-card {
    background: var(--bg-card);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 36px 30px 28px;
    position: relative;
    transition: all 0.2s ease;
    display: flex;
    flex-direction: column;
  }
  .weg-card:hover { border-color: var(--yellow); transform: translateY(-2px); }
  .weg-letter {
    position: absolute;
    top: 24px;
    left: 28px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 3rem;
    font-weight: 800;
    color: var(--yellow);
    line-height: 1;
    opacity: 1;
  }
  .weg-tag {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin-bottom: 24px;
    margin-left: 80px;
  }
  .weg-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.18rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 12px;
    line-height: 1.3;
    padding-right: 0;
  }
  .weg-card p {
    color: var(--ink-soft);
    font-size: 0.96rem;
    line-height: 1.55;
    margin: 0 0 22px;
    flex-grow: 1;
  }
  .weg-locked {
    background: rgba(245,197,24,0.1);
    border: 1px solid rgba(245,197,24,0.3);
    border-radius: 8px;
    padding: 12px 16px;
    color: var(--yellow);
    font-size: 0.86rem;
    font-weight: 600;
    text-align: center;
    margin-top: auto;
  }

  /* CREDIBILITY-SEKTION (direkt unter Hero) — Grau-Stufe für Differenzierung */
  .credibility {
    background: #15141a;
    padding: 80px 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }
  .cred-intro {
    max-width: 720px;
    margin-bottom: 40px;
  }
  .cred-eyebrow {
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: 14px;
    display: block;
  }
  .cred-headline {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    font-weight: 700;
    line-height: 1.25;
    color: var(--ink);
    letter-spacing: -0.015em;
    margin-bottom: 12px;
  }
  .cred-headline .yellow { color: var(--yellow); }
  .cred-sub {
    color: var(--ink-soft);
    font-size: 0.98rem;
    margin: 0;
    max-width: 640px;
  }

  .cred-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: stretch;
  }
  @media (max-width: 900px) { .cred-grid { grid-template-columns: 1fr; } }

  .cred-card {
    background: #1f1d24;
    border: 1px solid #2e2c34;
    border-radius: 22px;
    padding: 28px 26px;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .cred-card:hover { border-color: var(--yellow); transform: translateY(-2px); }

  .cred-tag {
    display: inline-block;
    background: #15141a;
    color: var(--ink-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    font-weight: 500;
    padding: 5px 11px;
    border-radius: 4px;
    margin-bottom: 18px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid #2e2c34;
    align-self: flex-start;
  }
  .cred-num {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.7rem, 3vw, 2.1rem);
    font-weight: 800;
    color: var(--yellow);
    line-height: 1.1;
    margin-bottom: 12px;
    letter-spacing: -0.025em;
    display: block;
  }
  .cred-card h4 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 10px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .cred-card p {
    color: var(--ink-soft);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
  }
  .cred-card .channels {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px dashed #2e2c34;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--ink-muted);
    letter-spacing: 0.04em;
  }
  .cred-footnote {
    margin-top: 30px;
    padding: 24px 30px;
    background: #1f1d24;
    border-left: 3px solid var(--yellow);
    border-radius: 4px;
    color: var(--ink-soft);
    font-size: 0.94rem;
    font-style: italic;
    line-height: 1.6;
  }
  .cred-footnote strong { color: var(--ink); font-style: normal; }
  .cred-footnote .signature {
    margin-top: 10px;
    display: block;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--yellow);
    font-style: normal;
    letter-spacing: 0.05em;
  }

  .hero-visual { position: relative; aspect-ratio: 4/5; display: flex; align-items: flex-start; justify-content: center; padding-top: 20px; }
  .hero-photo {
    width: 65%; height: auto; max-height: 70%; object-fit: contain;
    filter: drop-shadow(0 30px 50px rgba(0,0,0,0.5));
  }
  .live-sticker {
    position: absolute;
    top: 8%;
    right: -4%;
    background: var(--bg);
    border: 1.5px solid var(--line);
    border-radius: 14px;
    padding: 14px 18px;
    box-shadow: 0 18px 40px -10px rgba(0,0,0,0.6);
    transform: rotate(6deg);
    max-width: 200px;
    z-index: 4;
    text-align: center;
  }
  .live-sticker .live-dot {
    display: inline-block;
    background: #e63946;
    color: white;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    padding: 3px 9px;
    border-radius: 100px;
    margin-bottom: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }
  .live-sticker .live-dot::before {
    content: "● ";
    color: white;
  }
  .live-sticker .hint {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-style: italic;
    color: var(--ink);
    font-size: 0.95rem;
    line-height: 1.3;
    margin-bottom: 8px;
  }
  .live-sticker .views {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.66rem;
    color: var(--ink-muted);
  }
  .badge-praxis {
    position: absolute;
    bottom: 32%;
    left: 4%;
    background: var(--yellow);
    color: var(--ink-on-yellow);
    padding: 10px 16px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.3;
    z-index: 3;
  }
  @media (max-width: 900px) {
    .live-sticker { right: 0; top: 5%; max-width: 170px; }
  }

  /* YELLOW SECTION */
  .yellow-section { background: var(--yellow); color: var(--ink-on-yellow); padding: 90px 0; }
  .yellow-section h2, .yellow-section h3 { color: var(--ink-on-yellow); }
  .yellow-section p { color: rgba(14,13,11,0.78); }
  .yellow-section strong { color: var(--ink-on-yellow); }
  .yellow-section .eyebrow { font-weight: 700; font-size: 0.74rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(14,13,11,0.6); margin-bottom: 18px; display: block; }
  .yellow-section h2 { margin-bottom: 24px; max-width: 780px; }
  .yellow-section .lead { font-size: 1.12rem; color: rgba(14,13,11,0.78); max-width: 620px; margin-bottom: 50px; }

  .dark-section { padding: 90px 0; }
  .dark-section .eyebrow { font-weight: 700; font-size: 0.74rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 18px; display: block; }

  /* CARDS */
  .three-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 50px; }
  @media (max-width: 800px) { .three-cards { grid-template-columns: 1fr; } }
  .card { background: var(--bg-card); color: var(--ink); padding: 36px 30px; border-radius: 22px; border: 1px solid var(--line); }
  .card-num { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2.2rem; font-weight: 900; color: var(--yellow); line-height: 1; margin-bottom: 28px; display: block; }
  .card h3 { color: var(--ink); margin-bottom: 12px; }
  .card p { color: var(--ink-muted); font-size: 0.96rem; margin: 0; }

  /* REFLEX BOX (Selbst-Diagnose) */
  .reflex { background: var(--bg-card); border-radius: 16px; padding: 36px 32px; margin: 40px 0; border-left: 4px solid var(--yellow); }
  .reflex-label { display: inline-block; background: var(--yellow); color: var(--ink-on-yellow); font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; padding: 5px 12px; border-radius: 100px; margin-bottom: 18px; }
  .reflex-q { font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.3rem, 2.6vw, 1.7rem); font-weight: 600; line-height: 1.25; color: var(--ink); margin-bottom: 14px; letter-spacing: -0.015em; }
  .reflex-q .accent { color: var(--yellow); font-style: italic; }
  .reflex-sub { font-size: 0.95rem; color: var(--ink-muted); margin: 0; font-style: italic; }
  .yellow-section .reflex { background: var(--ink-on-yellow); color: var(--ink); border-left-color: var(--yellow); }
  .yellow-section .reflex-q { color: var(--ink); }
  .yellow-section .reflex-q .accent { color: var(--yellow); }
  .yellow-section .reflex-sub { color: var(--ink-muted); }

  /* SCHLÜSSELWORT */
  .schluessel { background: var(--bg-card-soft); border: 1px dashed var(--line); border-radius: 12px; padding: 22px 26px; margin: 26px 0; display: grid; grid-template-columns: auto 1fr; gap: 22px; align-items: start; }
  .schluessel-icon { width: 38px; height: 38px; background: var(--yellow); color: var(--ink-on-yellow); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 900; font-size: 1.3rem; flex-shrink: 0; }
  .schluessel-term { font-family: 'Plus Jakarta Sans', sans-serif; font-weight: 700; color: var(--yellow); font-size: 1rem; margin-bottom: 4px; display: block; letter-spacing: 0.02em; }
  .schluessel-def { color: var(--ink-soft); font-size: 0.96rem; line-height: 1.55; margin: 0; }
  .yellow-section .schluessel { background: var(--ink-on-yellow); border-color: rgba(245,197,24,0.4); }
  .yellow-section .schluessel-term { color: var(--yellow); }
  .yellow-section .schluessel-def { color: var(--ink-soft); }

  /* TRACKER */
  .tracker-wrap { background: var(--bg-card); border-radius: 18px; padding: 42px 36px; margin-top: 40px; border: 1px solid var(--line); }
  .tracker-header { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 16px; margin-bottom: 28px; padding-bottom: 22px; border-bottom: 1px solid var(--line); }
  .tracker-eyebrow { font-weight: 700; font-size: 0.7rem; color: var(--yellow); text-transform: uppercase; letter-spacing: 0.14em; margin-bottom: 8px; display: block; }
  .tracker-title { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.55rem; font-weight: 700; color: var(--ink); }
  .tracker-streak { font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; color: var(--ink-muted); }
  .tracker-streak strong { font-size: 1.6rem; color: var(--yellow); font-family: 'Plus Jakarta Sans', sans-serif; }
  .days { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 24px; }
  .day { aspect-ratio: 1; border: 1.5px solid var(--line); background: var(--bg-card-soft); cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; font-family: 'JetBrains Mono', monospace; transition: all 0.18s ease; user-select: none; position: relative; border-radius: 12px; }
  .day:hover { transform: translateY(-2px); border-color: var(--yellow); }
  .day-label { font-size: 0.65rem; color: var(--ink-muted); text-transform: uppercase; letter-spacing: 0.1em; }
  .day-num { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 2rem; font-weight: 800; margin-top: 4px; color: var(--ink); }
  .day.done { background: var(--yellow); border-color: var(--yellow); }
  .day.done::after { content: "✓"; position: absolute; top: 8px; right: 12px; font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; color: var(--ink-on-yellow); font-weight: 800; }
  .day.done .day-label, .day.done .day-num { color: var(--ink-on-yellow); }
  .tracker-cta { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
  .btn { padding: 14px 26px; background: var(--yellow); color: var(--ink-on-yellow); font-weight: 700; font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase; border: none; cursor: pointer; border-radius: 4px; transition: all 0.15s ease; }
  .btn:hover { background: var(--yellow-soft); transform: translateY(-1px); }
  .btn-ghost { background: transparent; color: var(--ink-soft); border: 1px solid var(--line); padding: 13px 22px; font-size: 0.78rem; }
  .btn-ghost:hover { background: var(--bg-card-soft); color: var(--ink); border-color: var(--ink-muted); }
  .tracker-msg { margin-top: 20px; padding: 16px 20px; background: rgba(245,197,24,0.1); border-left: 3px solid var(--yellow); border-radius: 4px; font-size: 0.95rem; color: var(--yellow); font-weight: 500; display: none; }
  .tracker-msg.show { display: block; animation: fadeIn 0.3s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }

  /* REMINDER BOX (Kalender-Download) */
  .reminder-box {
    margin-top: 24px;
    background: var(--ink-on-yellow);
    border-radius: 22px;
    padding: 32px 30px;
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    align-items: start;
  }
  .reminder-icon {
    width: 60px;
    height: 60px;
    background: rgba(245,197,24,0.15);
    border: 1.5px solid var(--yellow);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.7rem;
  }
  .reminder-content h3 {
    color: var(--ink);
    font-size: 1.2rem;
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .reminder-content p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    margin: 0 0 18px;
    line-height: 1.55;
  }
